# Database
POSTGRES_DB=msr_command_center
POSTGRES_USER=msr
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

# API
ASPNETCORE_ENVIRONMENT=Production
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=msr_command_center;Username=msr;Password=change-me
Jwt__Issuer=msr-command-center
Jwt__Audience=msr-command-center-web
Jwt__SigningKey=replace-with-a-long-random-secret-key-at-least-32-chars
Cors__AllowedOrigins=https://flowforge-sigma-six.vercel.app
Serilog__MinimumLevel__Default=Information

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000

# Enterprise auth
EnterpriseAuth__ApiBaseUrl=http://localhost:8080
EnterpriseAuth__FrontendBaseUrl=http://localhost:3000

# SMTP
Smtp__Host=localhost
Smtp__Port=1025
Smtp__User=
Smtp__Password=
Smtp__FromAddress=no-reply@msr.local
Smtp__FromName=MSR Command Center

# Storage
Storage__RootPath=./data/uploads
